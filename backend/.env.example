# Server
PORT=5000
NODE_ENV=production

# Security - CHANGE THIS! Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Database path (Railway uses ephemeral FS; consider adding a volume)
DB_PATH=./taskmanager.db

# Optional: restrict CORS to your frontend URL
# FRONTEND_URL=https://your-app.up.railway.app
